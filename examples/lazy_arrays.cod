// lazy_arrays.cod — O(1) lazy arrays and formula-optimized loops
// Run: coderive examples/lazy_arrays.cod
//
// Demonstrates:
//   - NaturalArray: create huge arrays in constant time
//   - Formula-optimized loops (pattern detected in O(1))
//   - Lexicographic ranges  (["a" to "z"])
//   - Range indexing         (arr[5 to 15])
//   - .size property

share main() {

    out("=== O(1) Lazy Array Creation ===")
    out("Creating an array of 1 Quintillion elements...")

    start := timer()
    huge : [text] = [0 to 1Qi]
    t := timer() - start

    out("Done in {t} ms  (O(1) — no elements generated yet)")
    out("")

    // The loop is detected as a conditional formula — still O(1)
    out("=== Formula-Optimized Loop ===")
    out("Labelling every element as 'even' or 'odd'...")

    start = timer()
    for i of huge {
        if i % 2 == 0 {
            huge[i] = "even"
        } else {
            huge[i] = "odd"
        }
    }
    loop_t := timer() - start

    out("Pattern recorded in {loop_t} ms  (formula, not 1Qi iterations)")
    out("")
    out("Spot-checks:")
    out("  huge[2]     = {huge[2]}")
    out("  huge[3]     = {huge[3]}")
    out("  huge[24K]   = {huge[24K]}")
    out("  huge[24001] = {huge[24001]}")

    out("")
    out("=== Lexicographic Ranges ===")
    alphabet := ["a" to "z"]
    out("Alphabet: {alphabet[0]} to {alphabet[25]}  ({alphabet.size} letters)")

    vowels := ["a" to "z" by 2]
    out("Every other letter: {vowels[0]}, {vowels[1]}, {vowels[2]} ...  ({vowels.size} total)")

    out("")
    out("=== Range Indexing  (slice without copying) ===")
    nums := [1 to 100]
    slice := nums[10 to 20]
    out("nums[10 to 20]:")
    out("  slice[0] = {slice[0]}  (should be 11)")
    out("  slice[5] = {slice[5]}  (should be 16)")

    out("")
    out("=== Range Assignment ===")
    grid : [text] = [0 to 50]
    grid[10 to 20] = "highlight"
    out("grid[15] = {grid[15]}  (should be 'highlight')")
    out("grid[25] = {grid[25]}  (should be 25)")
}
