// calculator.cod — Interactive calculator using Coderive's multi-return slots
// Run: coderive examples/calculator.cod
//
// Demonstrates:
//   - Multi-return slot system  (:: result: type, name: type)
//   - Slot assignment           (~> value, value)
//   - Slot destructuring        (a, b := [slot1, slot2]:method())
//   - any[] for validation      (op == any["+", "-", "*", "/"])
//   - String interpolation      ("{variable}")

share Calculator {

    local compute(a: int, b: int, op: text)
    :: result: int|float, operation: text {
        if op == "+" {
            ~> a + b, "addition"
        } else if op == "-" {
            ~> a - b, "subtraction"
        } else if op == "*" {
            ~> a * b, "multiplication"
        } else if op == "/" {
            ~> a / b, "division"
        } else {
            ~> 0, "unknown operation"
        }
    }

    share main() {
        out("=== Coderive Calculator ===")
        out("")

        a  := in(int,  "First number:  ")
        b  := in(int,  "Second number: ")
        op := in(text, "Operation (+, -, *, /): ")

        if op == any["+", "-", "*", "/"] {
            answer, name := [result, operation]:compute(a, b, op)

            out("")
            out("Result: {a} {op} {b} = {answer}")
            out("Operation: {name}")
        } else {
            out("")
            out("'{op}' is not a valid operator.")
            out("Please use one of: +  -  *  /")
        }
    }
}
