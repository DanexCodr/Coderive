// fizzbuzz.cod — FizzBuzz in Coderive
// Run: coderive examples/fizzbuzz.cod
//
// Demonstrates:
//   - all[] (AND logic) instead of &&
//   - for...of loops
//   - Clean, readable control flow

out("=== FizzBuzz (1 to 30) ===")
out("")

for i of 1 to 30 {
    if all[i % 3 == 0, i % 5 == 0] {
        out("{i} → FizzBuzz")
    } else if i % 3 == 0 {
        out("{i} → Fizz")
    } else if i % 5 == 0 {
        out("{i} → Buzz")
    } else {
        out(i)
    }
}
