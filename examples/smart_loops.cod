// smart_loops.cod — Coderive's expressive loop patterns
// Run: coderive examples/smart_loops.cod
//
// Demonstrates:
//   - Natural counting & auto-reverse
//   - Additive steps (by +N / by -N)
//   - Multiplicative steps (by *N)
//   - Divisive steps (by /N)
//   - Inline range formula shorthand (start..end#*factor)

share main() {

    out("=== Natural counting ===")
    for i of 1 to 5 {
        out(i)
    }

    out("")
    out("=== Auto-reverse (smart default step) ===")
    for i of 5 to 1 {
        out(i)
    }

    out("")
    out("=== Countdown with explicit step ===")
    for i of 10 to 1 by -2 {
        outs(i)
        outs(" ")
    }
    out()

    out("")
    out("=== Powers of 2  (multiplicative step) ===")
    exp := 0
    for i of 1 to 64 by *2 {
        out("2^{exp} = {i}")
        exp = exp + 1
    }

    out("")
    out("=== Halving sequence  (divisive step) ===")
    for i of 64 to 1 by /2 {
        outs(i)
        outs(" ")
    }
    out()

    out("")
    out("=== Inline formula shorthand  (1..32#*2) ===")
    for i of 1..32#*2 {
        outs(i)
        outs(" ")
    }
    out()

    out("")
    out("=== Skip even numbers  (by 2) ===")
    for i of 1 to 20 by 2 {
        outs(i)
        outs(" ")
    }
    out()
}
