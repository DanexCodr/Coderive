unit internal.range

share RangeSpec {
    step: int = 1
    start: int = 0
    end: int = 0

    share this(stepValue: int, startValue: int, endValue: int) {
        step = stepValue
        start = startValue
        end = endValue
    }

    share toText() :: text {
        if this.step != 1 {
            ~> ("RangeSpec\{by " + this.step + " in " + this.start + " to " + this.end + "}")
        }
        ~> ("RangeSpec\{" + this.start + " to " + this.end + "}")
    }

    share format(stepValue: int, startValue: int, endValue: int) :: text {
        if stepValue != 1 {
            ~> ("RangeSpec\{by " + stepValue + " in " + startValue + " to " + endValue + "}")
        }
        ~> ("RangeSpec\{" + startValue + " to " + endValue + "}")
    }
}
