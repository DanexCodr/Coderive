unit test.unsafe (main: this)

share unsafe BorrowBox {
    buffer: u8[4]

    share unsafe trigger() {
        buffer[0] = 1
        p: *u8 = &buffer[0]
        buffer[0] = 2
        out(*p)
    }
}

share BorrowMain {
    share main() {
        box: BorrowBox = safe(BorrowBox())
        safe(box.trigger())
    }
}
