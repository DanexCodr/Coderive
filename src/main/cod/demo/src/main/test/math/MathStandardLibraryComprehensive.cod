unit test.math

use {math.**}

share MathStandardLibraryComprehensive {
    share main() {
        out("== core ==")
        out(abs(-7))
        out(sign(-4))
        out(min(3, 9))
        out(max(3, 9))
        out(lerp(0, 10, 0.25))
        out(floor(-1.2))
        out(ceil(-1.2))
        out(round(2.6))
        out(trunc(-2.9))
        out(frac(5.75))
        out(pow(2, 10))
        out(sqrt(81))
        out(cbrt(27))
        out(hypot(3, 4))
        out(round(exp(1) * 1000) / 1000)
        out(round(log(exp(1)) * 1000) / 1000)
        out(round(log10(1000) * 1000) / 1000)
        out(round(log2(8) * 1000) / 1000)
        out(round(toDegrees(toRadians(180)) * 1000) / 1000)

        out("== trig ==")
        rightAngle := toRadians(90)
        out(round(sin(rightAngle) * 1000) / 1000)
        out(round(cos(rightAngle) * 1000) / 1000)
        out(round(tan(toRadians(45)) * 1000) / 1000)
        out(round(asin(1) * 1000) / 1000)
        out(round(acos(1) * 1000) / 1000)
        out(round(atan(1) * 1000) / 1000)
        out(round(atan2(1, 1) * 1000) / 1000)

        out("== number theory ==")
        out(fibonacci(10))
        out(gcd(84, 18))
        out(lcm(21, 6))
        out(isPrime(97))
        out(nextPrime(97))
        out(prevPrime(97))
        factors := factorize(84)
        out(factors.size)
        out(factors[0])
        out(factors[1])
        out(factors[2])
        out(factors[3])
        out(factorial(6))
        out(permutations(5, 3))
        out(combinations(5, 3))
        out(binomial(5, 2))

        out("== random ==")
        randomSeed(42)
        r0 := random()
        r1 := random(10)
        r2 := random(5, 9)
        out(all[r0 >= 0, r0 < 1])
        out(all[r1 >= 0, r1 < 10])
        out(all[r2 >= 5, r2 <= 9])
        out(randomGaussian())

        out("== linear algebra ==")
        out(dot([1, 2, 3], [4, 5, 6]))
        crossVec := cross([1, 2, 3], [4, 5, 6])
        out(crossVec[0])
        out(crossVec[1])
        out(crossVec[2])
        out(magnitude([3, 4]))
        normalized := normalize([3, 4])
        out(round(normalized[0] * 1000) / 1000)
        out(round(normalized[1] * 1000) / 1000)
        product := matmul([[1, 2], [3, 4]], [[2, 0], [1, 2]])
        out(product[0][0])
        out(product[0][1])
        out(product[1][0])
        out(product[1][1])
        transposed := transpose([[1, 2, 3], [4, 5, 6]])
        out(transposed[0][0])
        out(transposed[0][1])
        out(transposed[2][0])
        out(transposed[2][1])
        idMat := identity(3)
        out(idMat[0][0])
        out(idMat[0][1])
        out(idMat[2][2])
        out(determinant([[1, 2], [3, 4]]))

        out("== stats ==")
        values := [1, 2, 2, 3, 4]
        out(mean(values))
        out(median(values))
        out(mode(values))
        out(variance(values))
        out(round(stddev(values) * 1000) / 1000)
        runningMeans := runningMean(values)
        out(runningMeans[0])
        out(runningMeans[4])
        runningStds := runningStddev(values)
        out(round(runningStds[0] * 1000) / 1000)
        out(round(runningStds[4] * 1000) / 1000)
    }
}
