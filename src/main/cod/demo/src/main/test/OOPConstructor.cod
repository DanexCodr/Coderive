unit test

policy Named {
    name() :: text
}

share Person with Named {
    age: int = 0
    label: text = "unset"
    
    share this(labelText: text, ageValue: int) {
        label = labelText
        age = ageValue
    }
    
    policy name() :: text {
        ~> label
    }
    
    share getAge() :: int {
        ~> this.age
    }
}

share OOPCtorMain {
    share main() {
        person := Person("alex", 20)
        out("ctor-ok")
    }
}
