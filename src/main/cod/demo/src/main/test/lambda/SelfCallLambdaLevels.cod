unit test.lambda

share SelfCallLambdaLevels {
    share main() {
        a := 2
        levels := 0
        levels = [result]:\(a: int) :: result: int {
            if a <= 0 {
                ~> result: 0
            }

            b := a
            mid := 0
            mid = [result]:\(b: int) :: result: int {
                if b <= 0 {
                    ~> result: 0
                }

                c := b
                inner := 0
                inner = [result]:\(c: int) :: result: int {
                    if c <= 0 {
                        ~> result: 0
                    }

                    selfShortcut := <~(c - 1)
                    selfExplicit := <~0(c - 1)
                    parent := <~1(c - 1)
                    grandparent := <~2(c - 1)

                    ~> result: c + selfShortcut + selfExplicit + parent + grandparent
                }

                ~> result: inner
            }

            ~> result: mid
        }

        out("levels=" + levels)
    }
}
