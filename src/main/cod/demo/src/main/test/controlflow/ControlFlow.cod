unit test.controlflow

share ControlFlow {
    share main() {
        out("control-flow:start")

        sum := 0
        for i of 1 to 10 {
            if i == 3 {
                skip
            }
            if i == 8 {
                break
            }
            sum = sum + i
        }

        out("sum=" + sum)

        out("fin:before")
        fin
        out("fin:after-should-not-print")
    }
}
