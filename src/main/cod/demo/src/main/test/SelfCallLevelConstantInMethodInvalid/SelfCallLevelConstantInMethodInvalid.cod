unit test.SelfCallLevelConstantInMethodInvalid

share SelfCallLevelConstantInMethodInvalid {
    local bad(n: int) :: result: int {
        LEVEL := 0
        if n < 2 {
            ~> result: 1
        }
        ~> result: n * <~LEVEL(n - 1)
    }

    share main() {
        out([result]:bad(4))
    }
}
