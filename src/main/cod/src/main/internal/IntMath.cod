unit internal

share IntMath {
    share abs(value: int) :: int {
        if value < 0 {
            ~> -value
        }
        ~> value
    }

    share max(a: int, b: int) :: int {
        if a > b {
            ~> a
        }
        ~> b
    }

    share min(a: int, b: int) :: int {
        if a < b {
            ~> a
        }
        ~> b
    }

    share clamp(value: int, low: int, high: int) :: int {
        if value < low {
            ~> low
        }
        if value > high {
            ~> high
        }
        ~> value
    }
}
