unit test

share TypeAndTupleDemo {
    share main() {
        point: (int, text, bool) = (7, "x", true)
        out("tuple-a=" + point[0])
        out("tuple-b=" + point[1])
        out("tuple-c=" + point[2])

        whole := 9
        ratio := 9.5
        label := "coderive"
        flag := false

        out("whole-is-int=" + (whole is int))
        out("ratio-is-float=" + (ratio is float))
        out("label-is-text=" + (label is text))
        out("flag-is-bool=" + (flag is bool))
    }
}

