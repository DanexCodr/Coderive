unit test

share LoopWithIOTest {

share main() {
resultArr := [0 to 100K]

start := timer()
for i of [0 to 5] {
    val := i * 2
    out(val)
    resultArr[i] = val
}
output_time := timer() - start

out("Output-aware loop time: " + output_time + " ms")

resultArr = [0 to 100K]

start = timer()
for i of [0 to 10] {
    val := i * 2
    out(val)
    resultArr[i] = val
}
output_time = timer() - start

out("Output-aware loop time: " + output_time + " ms")

resultArr = [0 to 100K]

start = timer()
for i of [0 to 100] {
    val := i * 2
    out(val)
    resultArr[i] = val
}
output_time = timer() - start

out("Output-aware loop time: " + output_time + " ms")

resultArr = [0 to 100K]

start = timer()
for i of [0 to 1000] {
    val := i * 2
    out(val)
    resultArr[i] = val
}
output_time = timer() - start

out("Output-aware loop time: " + output_time + " ms")

}
}