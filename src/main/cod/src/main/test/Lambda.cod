unit test

share LambdaDemo {
    local compute() :: sum: int, diff: int {
        x, y = [sum, diff]:\(a: int, b: int) :: sum: int, diff: int ~> sum: a + b, diff: a - b
        ~> sum: x, diff: y
    }
    
    share main() {
        sum, diff := [sum, diff]:compute()
        out(sum)
        out(diff)
    }
}
