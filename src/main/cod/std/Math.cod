unit std

use { math.** }

share Math {
    share abs(x: int|float) :: int|float { ~> math.abs(x) }
    share min(a: int|float, b: int|float) :: int|float { ~> math.min(a, b) }
    share max(a: int|float, b: int|float) :: int|float { ~> math.max(a, b) }
    share pow(base: int|float, exponent: int) :: int|float { ~> math.pow(base, exponent) }
    share sqrt(x: int|float) :: int|float { ~> math.sqrt(x) }
}
