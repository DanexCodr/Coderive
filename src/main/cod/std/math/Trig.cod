unit math

// Trigonometric and hyperbolic utilities.
share Trig {
    PI: float = 3.141592653589793

    share normalizeAngle(x: int|float) :: int|float {
        twoPi: float = 6.283185307179586
        y: int|float = x
        for i of 1 to 8 {
            if y > PI {
                y = y - twoPi
            } elif y < (0 - PI) {
                y = y + twoPi
            }
        }
        ~> (y)
    }

    share sin(x: int|float) :: int|float {
        y := Trig.normalizeAngle(x)
        termValue: int|float = y
        sum: int|float = y
        for i of 1 to 12 {
            a: int = 2 * i
            b: int = 2 * i + 1
            termValue = termValue * y * y / (a * b)
            if i % 2 == 1 {
                sum = sum - termValue
            } else {
                sum = sum + termValue
            }
        }
        ~> (sum)
    }

    share cos(x: int|float) :: int|float {
        y := Trig.normalizeAngle(x)
        termValue: int|float = 1
        sum: int|float = 1
        for i of 1 to 12 {
            a: int = 2 * i - 1
            b: int = 2 * i
            termValue = termValue * y * y / (a * b)
            if i % 2 == 1 {
                sum = sum - termValue
            } else {
                sum = sum + termValue
            }
        }
        ~> (sum)
    }

    share tan(x: int|float) :: int|float {
        c := Trig.cos(x)
        if c == 0 { ~> (0) }
        ~> (Trig.sin(x) / c)
    }

    share atan(x: int|float) :: int|float {
        if x > 1 {
            ~> (PI / 2 - Trig.atan(1 / x))
        }
        if x < (0 - 1) {
            ~> ((0 - PI / 2) - Trig.atan(1 / x))
        }
        termValue: int|float = x
        sum: int|float = x
        for i of 1 to 24 {
            n: int = 2 * i + 1
            termValue = termValue * x * x
            if i % 2 == 1 {
                sum = sum - termValue / n
            } else {
                sum = sum + termValue / n
            }
        }
        ~> (sum)
    }

    share atan2(y: int|float, x: int|float) :: int|float {
        if x > 0 { ~> (Trig.atan(y / x)) }
        if x < 0 {
            if y >= 0 { ~> (Trig.atan(y / x) + PI) }
            ~> (Trig.atan(y / x) - PI)
        }
        if y > 0 { ~> (PI / 2) }
        if y < 0 { ~> (0 - PI / 2) }
        ~> (0)
    }

    share asin(x: int|float) :: int|float {
        if x > 1 { ~> (PI / 2) }
        if x < (0 - 1) { ~> (0 - PI / 2) }
        ~> (Trig.atan2(x, Core.sqrt(1 - x * x)))
    }

    share acos(x: int|float) :: int|float {
        ~> (PI / 2 - Trig.asin(x))
    }

    share sinh(x: int|float) :: int|float {
        ex := Core.exp(x)
        enx := Core.exp(0 - x)
        ~> ((ex - enx) / 2)
    }

    share cosh(x: int|float) :: int|float {
        ex := Core.exp(x)
        enx := Core.exp(0 - x)
        ~> ((ex + enx) / 2)
    }

    share tanh(x: int|float) :: int|float {
        c := Trig.cosh(x)
        if c == 0 { ~> (0) }
        ~> (Trig.sinh(x) / c)
    }

    share asinh(x: int|float) :: int|float {
        ~> (Core.log(x + Core.sqrt(x * x + 1)))
    }

    share acosh(x: int|float) :: int|float {
        if x < 1 { ~> (0) }
        ~> (Core.log(x + Core.sqrt(x * x - 1)))
    }

    share atanh(x: int|float) :: int|float {
        if x >= 1 { ~> (0) }
        if x <= (0 - 1) { ~> (0) }
        ~> (0.5 * Core.log((1 + x) / (1 - x)))
    }
}
