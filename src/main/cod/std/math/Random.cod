unit math

// Pseudo-random number generation utilities for integer and gaussian sampling.
share Random {
    seed: int = 123456789

    share randomSeed(newSeed: int) {
        seed = newSeed
    }

    share nextRaw() :: int|float {
        seed = (1103515245 * seed + 12345) % 2147483647
        if seed < 0 {
            seed = -seed
        }
        ~> (seed)
    }

    share random() :: int|float {
        ~> (Random.nextRaw() / 2147483647)
    }

    share random(max: int) :: int|float {
        if max <= 0 { ~> (0) }
        ~> (Random.nextRaw() % max)
    }

    share random(min: int, max: int) :: int|float {
        if max <= min { ~> (min) }
        span: int = max - min + 1
        ~> (min + (Random.nextRaw() % span))
    }

    share randomGaussian() :: int|float {
        u1 := Random.random()
        if u1 <= 0 {
            u1 = 0.000001
        }
        u2 := Random.random()
        r := Core.sqrt(-2 * Core.log(u1))
        theta := 6.283185307179586 * u2
        ~> (r * Trig.cos(theta))
    }
}
