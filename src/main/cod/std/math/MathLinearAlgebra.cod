unit math

share LinearAlgebra {
    share minInt(a: int, b: int) :: int|float {
        if a < b { ~> a }
        ~> b
    }

    share dot(a: [], b: []) :: int|float {
        n := LinearAlgebra.minInt(a.size, b.size)
        sum: int|float = 0
        if n <= 0 { ~> 0 }
        for i of 0 to n - 1 {
            sum = sum + a[i] * b[i]
        }
        ~> sum
    }

    share cross(a: [], b: []) :: [] {
        if a.size < 3 { ~> [0, 0, 0] }
        if b.size < 3 { ~> [0, 0, 0] }
        ~> [
            a[1] * b[2] - a[2] * b[1],
            a[2] * b[0] - a[0] * b[2],
            a[0] * b[1] - a[1] * b[0]
        ]
    }

    share magnitude(a: []) :: int|float {
        ~> Core.sqrt(LinearAlgebra.dot(a, a))
    }

    share normalize(a: []) :: [] {
        mag := LinearAlgebra.magnitude(a)
        if mag == 0 { ~> a }
        outArr := [0 to a.size - 1]
        for i of 0 to a.size - 1 {
            outArr[i] = a[i] / mag
        }
        ~> outArr
    }

    share transpose(a: []) :: [] {
        if a.size == 0 { ~> [] }
        firstRow := a[0]
        cols := firstRow.size
        outArr := [0 to cols - 1]
        for c of 0 to cols - 1 {
            outArr[c] = [0 to a.size - 1]
            for r of 0 to a.size - 1 {
                outArr[c][r] = a[r][c]
            }
        }
        ~> outArr
    }

    share identity(n: int) :: [] {
        if n <= 0 { ~> [] }
        outArr := [0 to n - 1]
        for r of 0 to n - 1 {
            outArr[r] = [0 to n - 1]
            for c of 0 to n - 1 {
                if r == c {
                    outArr[r][c] = 1
                } else {
                    outArr[r][c] = 0
                }
            }
        }
        ~> outArr
    }

    share matmul(a: [], b: []) :: [] {
        if a.size == 0 { ~> [] }
        if b.size == 0 { ~> [] }
        rows := a.size
        firstA := a[0]
        firstB := b[0]
        inner := firstA.size
        cols := firstB.size
        outArr := [0 to rows - 1]
        for r of 0 to rows - 1 {
            outArr[r] = [0 to cols - 1]
            for c of 0 to cols - 1 {
                sum: int|float = 0
                for k of 0 to inner - 1 {
                    sum = sum + a[r][k] * b[k][c]
                }
                outArr[r][c] = sum
            }
        }
        ~> outArr
    }

    share determinant(a: []) :: int|float {
        if a.size == 0 { ~> 0 }
        if a.size == 1 { ~> a[0][0] }
        if a.size == 2 {
            ~> a[0][0] * a[1][1] - a[0][1] * a[1][0]
        }
        ~> 0
    }
}
